# Finnhub API — cotações de ações americanas e cripto
# Cadastro grátis em: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Brapi.dev API — cotações de ações brasileiras (B3)
# Cadastro grátis em: https://brapi.dev/dashboard
BRAPI_API_TOKEN=your_brapi_token_here

# Nome público do app (não-secret)
NEXT_PUBLIC_APP_NAME=FX Dashboard